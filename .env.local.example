# Supabase — copy this file to `.env.local` and fill in your project values.
# Found under: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Saved designs: enable Authentication → Providers → Anonymous sign-ins,
# then run supabase/saved_components.sql in the SQL Editor.

# Google AdSense (public publisher id — safe in the browser)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-1639618674141767

# Public site URL for sitemap, Open Graph, and share links
NEXT_PUBLIC_SITE_URL=https://tailwind-visual-hub.vercel.app

# Optional: create display ad units in AdSense, then paste slot ids here
# NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
# NEXT_PUBLIC_ADSENSE_SLOT_SHADOW=
# NEXT_PUBLIC_ADSENSE_SLOT_GRADIENT=
